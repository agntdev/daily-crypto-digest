# Required: Telegram Bot API token (from @BotFather)
BOT_TOKEN=

# Optional: Crypto news API keys (at least one for real news)
# NewsData.io API key — https://newsdata.io
NEWS_API_KEY=
# NewsAPI.org API key — https://newsapi.org
NEWSAPI_KEY=

# Optional: Redis for persistent storage (production)
REDIS_URL=

# Optional: Admin Telegram chat ID for daily reports/error alerts
BOT_ADMIN_CHAT_ID=

# Optional: Digest configuration
# Summary length limit in characters (default: 500)
DIGEST_SUMMARY_LIMIT=500
# Number of articles per digest (1-5, default: 3)
DIGEST_ARTICLE_COUNT=3