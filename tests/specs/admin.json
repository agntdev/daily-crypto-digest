[
  {
    "name": "/admin shows the admin panel",
    "steps": [
      {
        "send": { "text": "/admin" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": { "parse_mode": "HTML" }
          }
        ]
      }
    ]
  },
  {
    "name": "/admin_setup configures the admin chat",
    "steps": [
      {
        "send": { "text": "/admin_setup" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": { "text": "✅ This chat is now set as the admin channel. Daily reports will be sent here." }
          }
        ]
      }
    ]
  },
  {
    "name": "/admin_users shows user stats",
    "steps": [
      {
        "send": { "text": "/admin_users" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": { "parse_mode": "HTML" }
          }
        ]
      }
    ]
  },
  {
    "name": "/admin_report generates report",
    "steps": [
      {
        "send": { "text": "/admin_report" },
        "expect": [
          { "method": "sendMessage", "payload": { "text": "📊 Generating delivery stats report..." } }
        ]
      }
    ]
  },
  {
    "name": "menu:main back to menu button works",
    "steps": [
      {
        "send": { "callback": "menu:main" },
        "expect": [
          { "method": "answerCallbackQuery" },
          {
            "method": "editMessageText",
            "payload": { "text": "👋 Welcome! This bot sends you 1–3 curated crypto news summaries each day at your chosen time." }
          }
        ]
      }
    ]
  }
]